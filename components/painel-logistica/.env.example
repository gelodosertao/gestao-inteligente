# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps Platform.
# Obtain at: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_PLATFORM_KEY=

# SUPABASE: Required for cloud persistence (multi-device sync).
# If not set, the app falls back to localStorage only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# VITE_TENANT_ID: UUID do tenant da empresa no banco de dados multi-tenant.
# Obter via: SELECT id, name FROM tenants; no SQL Editor do Supabase.
VITE_TENANT_ID=

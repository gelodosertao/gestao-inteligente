# Ambiente SEFAZ: 1 = Produção, 2 = Homologação
SEFAZ_AMBIENTE=2

# UF do emitente (BA para SEFAZ-BA)
SEFAZ_UF=BA

# Certificado digital A1 no formato Base64
# Obter com: certutil -encode certificado.pfx cert.txt (Windows) / base64 -i certificado.pfx (Linux/Mac)
CERTIFICADO_A1_BASE64=

# Senha do certificado digital A1
CERTIFICADO_PASSWORD=

# CNPJ do emitente (apenas números, 14 dígitos)
CNPJ_EMITENTE=

# Conexão com Supabase (para operações de escrita após emissão NF-e)
# Usar a chave service_role (NUNCA a anon key) — encontre em: Config → API → service_role key
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Modo de teste local (simulação local de XML sem consultar SEFAZ)
# Defina como 'true' para testes sem certificado/SEFAZ ativo
MOCK_LOCAL_ONLY=false

# Timeout para conexões webservice SEFAZ em milissegundos (default: 60000 - min: 5000, max: 300000)
SEFAZ_TIMEOUT_MS=60000

# Origem CORS permitida para requisições de clientes web (obrigatório domínio exato em produção)
SERVER_CORS_ORIGIN=*

# Token de autenticação Bearer para endpoints protegidos (obrigatório em produção)
API_AUTH_TOKEN=
